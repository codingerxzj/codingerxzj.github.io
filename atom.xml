</span><br><span class="line">61</span><br><span class="line">62</span><br><span class="line">63</span><br><span class="line">64</span><br></pre></td><td class="code"><pre><code class="hljs Java"><span class="hljs-keyword">import</span> sun.security.util.Length;<br><br><span class="hljs-keyword">import</span> java.util.Scanner;<br><br><span class="hljs-keyword">public</span> <span class="hljs-keyword">class</span> <span class="hljs-title class_">LongestString</span> &#123;<br>    <span class="hljs-comment">//自己输入用例来判断，或者用已存在的进行输入</span><br>    <span class="hljs-comment">//第一步写他的方法</span><br>    <span class="hljs-comment">// 最长回文子串：比如</span><br>    <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-keyword">void</span> <span class="hljs-title function_">main</span><span class="hljs-params">(String[] args)</span>&#123;<br><span class="hljs-comment">//方法一:自己输入用例输入</span><br><span class="hljs-comment">//        Scanner scanner =new Scanner(System.in);</span><br><span class="hljs-comment">//        String input =scanner.nextLine();</span><br><span class="hljs-comment">//        System.out.println(&quot;最长回文子串:&quot;+lengthOfLongestString(input));</span><br><span class="hljs-comment">//        int length=lengthOfLongestString(input).length();</span><br><span class="hljs-comment">//        System.out.println(&quot;最长回文子串的长度为：&quot;+length);</span><br><span class="hljs-comment">//方法二:自己设置样例</span><br>          String s=<span class="hljs-string">&quot;12345654&quot;</span>;<br>        System.out.println(<span class="hljs-string">&quot;最长回文子串:&quot;</span>+lengthOfLongestString(s));<br>        System.out.println(<span class="hljs-string">&quot;最长回文子串的长度：&quot;</span>+lengthOfLongestString(s).length());<br>    &#125;<br>    <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> String <span class="hljs-title function_">lengthOfLongestString</span><span class="hljs-params">(String s)</span>&#123;<br>        <span class="hljs-keyword">if</span>(s==<span class="hljs-literal">null</span> || s.length()==<span class="hljs-number">0</span>)&#123;<br>            <span class="hljs-keyword">return</span> <span class="hljs-string">&quot;&quot;</span>;<br>        &#125;<br>        <span class="hljs-type">int</span> start=<span class="hljs-number">0</span>;<br>        <span class="hljs-type">int</span> end=<span class="hljs-number">0</span>;<br>        <span class="hljs-keyword">for</span>(<span class="hljs-type">int</span> i=<span class="hljs-number">0</span>;i&lt;s.length();i++)&#123;<br>            <span class="hljs-comment">//expandAround函数的作用是向两边拓展，以找到以当前字符为中心的最长回文子串长度</span><br>            <span class="hljs-type">int</span> len1=expandAroundCenter(s,i,i);<span class="hljs-comment">//处理奇数长度的回文子串</span><br>            <span class="hljs-type">int</span> len2=expandAroundCenter(s,i,i+<span class="hljs-number">1</span>);<span class="hljs-comment">//处理偶数长度的回文子串</span><br>            <span class="hljs-type">int</span> len=Math.max(len2,len1);<br>            <span class="hljs-keyword">if</span>(len&gt;end-start)&#123;<br>                <span class="hljs-comment">//用于更新长度</span><br>                <span class="hljs-comment">//对于奇数长度的回文子串,中心字符本身就属于回文子串:所以起始位置是i-(len-1)/2</span><br>                start =i-(len-<span class="hljs-number">1</span>)/<span class="hljs-number">2</span>;<span class="hljs-comment">//想下取整</span><br>                end = i +len/<span class="hljs-number">2</span>;<span class="hljs-comment">//向上取整</span><br>            &#125;<br>        &#125;<br>        <span class="hljs-keyword">return</span> s.substring(start,end+<span class="hljs-number">1</span>);<br>    &#125;<br><br>    <span class="hljs-comment">/**</span><br><span class="hljs-comment">     * 计算回文子串的长度,从中间向两边拓展</span><br><span class="hljs-comment">     * <span class="hljs-doctag">@param</span> s</span><br><span class="hljs-comment">     * <span class="hljs-doctag">@param</span> left</span><br><span class="hljs-comment">     * <span class="hljs-doctag">@param</span> right</span><br><span class="hljs-comment">     * <span class="hljs-doctag">@return</span></span><br><span class="hljs-comment">     */</span><br>    <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-type">int</span> <span class="hljs-title function_">expandAroundCenter</span><span class="hljs-params">(String s,<span class="hljs-type">int</span> left,<span class="hljs-type">int</span> right)</span>&#123;<br>        <span class="hljs-type">int</span> L=left;<br>        <span class="hljs-type">int</span> R=right;<br>        <span class="hljs-type">int</span> length=<span class="hljs-number">0</span>;<br>        <span class="hljs-keyword">while</span>(L&gt;=<span class="hljs-number">0</span> &amp;&amp; R&lt;s.length() &amp;&amp; s.charAt(L)==s.charAt(R))&#123;<br>            <span class="hljs-comment">//s.chatAt(i):获取s在i位置的字符</span><br>            L--;<br>            R++;<br>        &#125;<br>        length=R-L-<span class="hljs-number">1</span>;<br>        <span class="hljs-keyword">return</span>  length;<br>    &#125;<br><br><br>&#125;<br><br></code></pre></td></tr></table></figure>]]></content>
    
    
      
      
